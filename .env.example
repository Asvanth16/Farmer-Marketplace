# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your actual MongoDB Atlas connection string in your local .env file
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/farmer_db?retryWrites=true&w=majority

# Security & Authentication
# Choose a strong random string for your local signing token
JWT_SECRET=your_super_secret_jwt_key_here